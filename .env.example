# Database
POSTGRES_USER=admin
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=job_platform
DATABASE_URL=postgresql://admin:your_password_here@postgres:5432/job_platform

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Redis
REDIS_URL=redis://redis:6379

# JWT
SECRET_KEY=your_secret_key_here

# Service Multipliers
AI_MULTIPLIER=1.3
ENGINEER_MULTIPLIER=1.1